---
import { eras, type FigureMeta, type Era } from "../data/chapters";

export interface Props {
  name: string;
  image: string;
  sourcePage?: string;
  meta?: FigureMeta;
  era?: Era;
  chapterSlugs?: Record<string, string>;
  linkToChapterPages?: boolean;
}

const { name, image, sourcePage, meta, era, chapterSlugs = {}, linkToChapterPages = false } = Astro.props;
---

<li class="glass-card figure-card rounded-2xl overflow-hidden">
  <div class="relative">
    <img
      src={image}
      alt={`Portrait of ${name}`}
      loading="lazy"
      decoding="async"
      class="aspect-[4/3] w-full object-cover"
    />
    {era && (
      <span class="figure-era-badge" style={`border: 1px solid ${era.color};`}>
        {era.label}
      </span>
    )}
    <div class="figure-overlay">
      <p class="font-display text-lg font-semibold">{name}</p>
      {meta?.years && <p class="text-xs opacity-70">{meta.years}</p>}
      {meta?.contribution && <p class="figure-contribution">{meta.contribution}</p>}
      <div class="figure-links">
        {meta?.wikipedia && (
          <a href={meta.wikipedia} target="_blank" rel="noreferrer">Wikipedia</a>
        )}
        {sourcePage && (
          <a href={sourcePage} target="_blank" rel="noreferrer">Image source</a>
        )}
        {meta?.chapters.map((ch) => {
          const slug = chapterSlugs[ch];
          const href = linkToChapterPages && slug ? `/chapters/${slug}` : `#ch-${ch}`;
          return <a href={href}>Ch. {ch}</a>;
        })}
      </div>
    </div>
  </div>
  <div class="p-4">
    <p class="font-semibold" style="color: var(--text-primary);">
      {meta?.wikipedia ? (
        <a href={meta.wikipedia} target="_blank" rel="noreferrer" class="no-underline" style="color: var(--text-primary);">
          {name} <span class="text-xs" style="color: var(--text-link);">&nearr;</span>
        </a>
      ) : name}
    </p>
    {meta?.contribution && (
      <p class="mt-0.5 text-xs" style="color: var(--text-secondary);">{meta.contribution}</p>
    )}
  </div>
</li>

<style>
  .figure-card {
    position: relative;
    overflow: hidden;
    transition: transform 300ms ease, box-shadow 300ms ease;
  }

  .figure-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgb(0 0 0 / 14%);
  }

  .figure-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgb(0 0 0 / 85%) 0%, rgb(0 0 0 / 40%) 40%, transparent 70%);
    opacity: 0;
    transition: opacity 350ms ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.2rem;
    color: #f6f5f1;
  }

  .figure-card:hover .figure-overlay {
    opacity: 1;
  }

  .figure-overlay .figure-contribution {
    font-size: 0.85rem;
    line-height: 1.45;
    margin-top: 0.35rem;
    opacity: 0.9;
  }

  .figure-overlay .figure-links {
    margin-top: 0.5rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .figure-overlay .figure-links a {
    font-size: 0.75rem;
    color: var(--color-teal-200);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .figure-overlay .figure-links a:hover {
    color: #fff;
  }

  .figure-era-badge {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    backdrop-filter: blur(6px);
    background: rgb(0 0 0 / 45%);
    color: #f6f5f1;
  }
</style>
