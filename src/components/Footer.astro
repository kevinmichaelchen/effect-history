---
import { base } from "../lib/base";

const currentYear = new Date().getFullYear();

const siteLinks = [
  { href: base("/chapters/1-the-lambda-calculus-computation-as-function-19321936"), label: "Chapters" },
  { href: base("/figures"), label: "Figures" },
  { href: base("/glossary"), label: "Glossary" },
  { href: base("/papers"), label: "Papers" },
  { href: base("/blog"), label: "Blog" },
  { href: "https://github.com/kevinmichaelchen/effect-history", label: "GitHub", external: true },
];

const effectLinks = [
  { href: "https://effect.website", label: "Effect" },
  { href: "https://effect.website/docs", label: "Documentation" },
  { href: "https://github.com/Effect-TS/effect", label: "GitHub" },
  { href: "https://discord.gg/effect-ts", label: "Discord" },
  { href: "https://twitter.com/EffectTS_", label: "Twitter / X" },
  { href: "https://www.youtube.com/@effect-ts", label: "YouTube" },
];

const conceptLinks = [
  { href: "https://en.wikipedia.org/wiki/Lambda_calculus", label: "Lambda Calculus" },
  { href: "https://en.wikipedia.org/wiki/Curry%E2%80%93Howard_correspondence", label: "Curry-Howard" },
  { href: "https://en.wikipedia.org/wiki/Category_theory", label: "Category Theory" },
  { href: "https://en.wikipedia.org/wiki/Monad_(functional_programming)", label: "Monads" },
  { href: "https://en.wikipedia.org/wiki/Algebraic_data_type", label: "ADTs" },
  { href: "https://en.wikipedia.org/wiki/Structured_concurrency", label: "Structured Concurrency" },
];
---

<footer class="site-footer" role="contentinfo">
  <!-- Decorative divider with lambda -->
  <div class="footer-divider" aria-hidden="true">
    <span class="footer-lambda">&lambda;</span>
  </div>

  <div class="mx-auto max-w-6xl px-6 pb-10 pt-10 md:px-8">
    <!-- Column grid -->
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href={base("/")} class="footer-brand font-display text-lg font-semibold no-underline">
          Effect Lineage
        </a>
        <p class="footer-description mt-3 text-sm leading-relaxed">
          A readable, visual journey through the ideas that shaped
          <a href="https://effect.website" target="_blank" rel="noreferrer">Effect</a> &mdash;
          from foundational logic to modern TypeScript.
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a href="https://github.com/kevinmichaelchen/effect-history" target="_blank" rel="noreferrer" class="footer-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
          <a href={base("/effect-intellectual-lineage.md")} class="footer-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            Raw markdown
          </a>
        </div>
      </div>

      <!-- Explore column -->
      <nav aria-label="Site pages">
        <h3 class="footer-heading">Explore</h3>
        <ul class="footer-list">
          {siteLinks.map((link) => (
            <li><a href={link.href} {...(link.external ? { target: "_blank", rel: "noreferrer" } : {})}>{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Effect ecosystem column -->
      <nav aria-label="Effect ecosystem">
        <h3 class="footer-heading">Effect Ecosystem</h3>
        <ul class="footer-list">
          {effectLinks.map((link) => (
            <li><a href={link.href} target="_blank" rel="noreferrer">{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Concepts column -->
      <nav aria-label="Key concepts">
        <h3 class="footer-heading">Key Concepts</h3>
        <ul class="footer-list">
          {conceptLinks.map((link) => (
            <li><a href={link.href} target="_blank" rel="noreferrer">{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-colophon">
        Built with
        <a href="https://astro.build" target="_blank" rel="noreferrer">Astro</a> &plus;
        <a href="https://tailwindcss.com" target="_blank" rel="noreferrer">Tailwind</a>
        for accessible technical storytelling.
      </p>
      <p class="footer-copyright">
        &copy; {currentYear}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    margin-top: 4rem;
    background: var(--bg-card);
    transition: background 300ms ease;
  }

  .footer-divider {
    position: relative;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--border-medium) 15%,
      var(--border-medium) 85%,
      transparent
    );
  }

  .footer-lambda {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    border: 1px solid var(--border-medium);
    background: var(--bg-page);
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--text-link);
    transition: background 300ms ease, border-color 300ms ease;
  }

  .footer-brand {
    color: var(--text-primary);
    transition: color 160ms ease;
  }

  .footer-brand:hover {
    color: var(--text-link);
  }

  .footer-description {
    color: var(--text-secondary);
    max-width: 26ch;
  }

  .footer-description a {
    color: var(--text-link);
    text-decoration: none;
    font-weight: 500;
  }

  .footer-description a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid var(--border-subtle);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-link);
    text-decoration: none;
    transition: background 160ms ease, border-color 160ms ease, color 160ms ease;
  }

  .footer-pill:hover {
    background: var(--text-link);
    border-color: var(--text-link);
    color: var(--bg-page);
  }

  .footer-heading {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-link);
    margin: 0 0 0.75rem;
  }

  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .footer-list a {
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 160ms ease;
  }

  .footer-list a:hover {
    color: var(--text-primary);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-colophon {
    font-size: 0.78rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .footer-colophon a {
    color: var(--text-link);
    text-decoration: none;
    font-weight: 500;
  }

  .footer-colophon a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-copyright {
    font-size: 0.78rem;
    color: var(--text-secondary);
    margin: 0;
    opacity: 0.6;
  }
</style>
