---
const currentYear = new Date().getFullYear();

const siteLinks = [
  { href: "/chapters/1-the-lambda-calculus-computation-as-function-19321936", label: "Chapters" },
  { href: "/figures", label: "Figures" },
  { href: "/glossary", label: "Glossary" },
  { href: "/papers", label: "Papers" },
  { href: "/blog", label: "Blog" },
];

const effectLinks = [
  { href: "https://effect.website", label: "Effect" },
  { href: "https://effect.website/docs", label: "Documentation" },
  { href: "https://github.com/Effect-TS/effect", label: "GitHub" },
  { href: "https://discord.gg/effect-ts", label: "Discord" },
  { href: "https://twitter.com/EffectTS_", label: "Twitter / X" },
  { href: "https://www.youtube.com/@effect-ts", label: "YouTube" },
];

const conceptLinks = [
  { href: "https://en.wikipedia.org/wiki/Lambda_calculus", label: "Lambda Calculus" },
  { href: "https://en.wikipedia.org/wiki/Curry%E2%80%93Howard_correspondence", label: "Curry-Howard" },
  { href: "https://en.wikipedia.org/wiki/Category_theory", label: "Category Theory" },
  { href: "https://en.wikipedia.org/wiki/Monad_(functional_programming)", label: "Monads" },
  { href: "https://en.wikipedia.org/wiki/Algebraic_data_type", label: "ADTs" },
  { href: "https://en.wikipedia.org/wiki/Structured_concurrency", label: "Structured Concurrency" },
];
---

<footer class="site-footer" role="contentinfo">
  <!-- Decorative divider with lambda -->
  <div class="footer-divider" aria-hidden="true">
    <span class="footer-lambda">&lambda;</span>
  </div>

  <div class="mx-auto max-w-6xl px-6 pb-10 pt-10 md:px-8">
    <!-- Column grid -->
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="footer-brand font-display text-lg font-semibold no-underline">
          Effect Lineage
        </a>
        <p class="footer-description mt-3 text-sm leading-relaxed">
          A readable, visual journey through the ideas that shaped
          <a href="https://effect.website" target="_blank" rel="noreferrer">Effect</a> &mdash;
          from foundational logic to modern TypeScript.
        </p>
        <div class="mt-4 flex gap-3">
          <a href="/effect-intellectual-lineage.md" class="footer-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            Raw markdown
          </a>
        </div>
      </div>

      <!-- Explore column -->
      <nav aria-label="Site pages">
        <h3 class="footer-heading">Explore</h3>
        <ul class="footer-list">
          {siteLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Effect ecosystem column -->
      <nav aria-label="Effect ecosystem">
        <h3 class="footer-heading">Effect Ecosystem</h3>
        <ul class="footer-list">
          {effectLinks.map((link) => (
            <li><a href={link.href} target="_blank" rel="noreferrer">{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Concepts column -->
      <nav aria-label="Key concepts">
        <h3 class="footer-heading">Key Concepts</h3>
        <ul class="footer-list">
          {conceptLinks.map((link) => (
            <li><a href={link.href} target="_blank" rel="noreferrer">{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-colophon">
        Built with
        <a href="https://astro.build" target="_blank" rel="noreferrer">Astro</a> &plus;
        <a href="https://tailwindcss.com" target="_blank" rel="noreferrer">Tailwind</a>
        for accessible technical storytelling.
      </p>
      <p class="footer-copyright">
        &copy; {currentYear}
      </p>
    </div>
  </div>
</footer>
