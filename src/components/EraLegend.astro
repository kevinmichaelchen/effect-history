---
import { eras } from "../data/chapters";

export interface Props {
  /** Show compact version (no year ranges) */
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class={`flex ${compact ? "gap-2 text-xs" : "flex-wrap gap-2 text-xs"}`} style="color: var(--text-secondary);">
  {eras.map((era) => (
    <span class="era-item flex items-center gap-1">
      <span class="era-dot inline-block h-2 w-2 rounded-full" style={`background: ${era.color};`} data-era-dot data-light-color={era.color} data-dark-color={era.darkColor}></span>
      <span class={compact ? "hidden sm:inline" : ""}>{era.label}</span>
      {!compact && <span class="opacity-60">({era.years})</span>}
    </span>
  ))}
</div>

<style>
  .era-item {
    transition: color 160ms ease;
  }

  .era-item:hover {
    color: var(--text-primary);
  }

  .era-dot {
    transition: transform 200ms ease, box-shadow 200ms ease;
  }

  .era-item:hover .era-dot {
    transform: scale(1.4);
    box-shadow: 0 0 6px currentColor;
  }
</style>
