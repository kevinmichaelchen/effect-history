---
import { eras, type ChapterMeta } from "../data/chapters";

export interface Props {
  chapterNumber: string;
  title: string;
  slug: string;
  summary: string;
  meta?: ChapterMeta;
  readingTime?: number;
  linkToPage?: boolean;
}

import { base } from "../lib/base";
const { chapterNumber, title, slug, summary, meta, readingTime, linkToPage = false } = Astro.props;
const era = meta ? eras[meta.eraIndex] : undefined;
const href = linkToPage ? base(`/chapters/${slug}`) : `#${slug}`;
---

<div class="chapter-card glass-card group rounded-2xl p-5" data-href={href}>
  <div class="flex items-center justify-between">
    <p class="text-xs font-semibold uppercase tracking-wider" style={`color: ${era?.color ?? "var(--text-link)"};`} data-era-element data-light-color={era?.color} data-dark-color={era?.darkColor}>
      Chapter {chapterNumber}
    </p>
    {meta?.yearRange && (
      <span class="text-theme-secondary text-xs">{meta.yearRange}</span>
    )}
  </div>
  <h3 class="text-theme-primary mt-1 font-display text-xl">{title}</h3>
  <p class="text-theme-secondary mt-2 text-sm">{summary}</p>
  {meta?.externalLinks && meta.externalLinks.length > 0 && (
    <div class="chapter-card-links">
      {meta.externalLinks.slice(0, 3).map((link) => (
        <a href={link.url} target="_blank" rel="noreferrer">
          {link.label}
        </a>
      ))}
    </div>
  )}
  {readingTime && (
    <p class="text-theme-secondary mt-2 text-xs">~{readingTime} min read</p>
  )}
</div>

<script>
  document.querySelectorAll<HTMLElement>(".chapter-card[data-href]").forEach((card) => {
    card.addEventListener("click", (e) => {
      // Don't navigate if user clicked an external link inside the card
      if ((e.target as HTMLElement).closest("a")) return;
      const href = card.dataset.href;
      if (href) window.location.href = href;
    });
  });
</script>

<style>
  .chapter-card {
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .chapter-card-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }

  .chapter-card-links a {
    display: inline-block;
    font-size: 0.7rem;
    line-height: 1.4;
    padding: 0.15rem 0.5rem;
    border-radius: 0.35rem;
    border: 1px solid var(--border-subtle);
    text-decoration: none;
    color: var(--text-link);
    transition: background 160ms ease, color 160ms ease;
    white-space: nowrap;
  }

  .chapter-card-links a:hover {
    background: var(--text-link);
    color: var(--bg-page);
  }
</style>
