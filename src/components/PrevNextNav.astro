---
export interface Props {
  prev?: { slug: string; title: string; chapterNumber: string };
  next?: { slug: string; title: string; chapterNumber: string };
}

import { base } from "../lib/base";
const { prev, next } = Astro.props;
---

<nav class="prev-next-nav mt-10 grid gap-4 sm:grid-cols-2" aria-label="Chapter navigation">
  {prev ? (
    <a href={base(`/chapters/${prev.slug}`)} class="prev-next-link glass-card rounded-2xl p-4 no-underline">
      <span class="text-theme-secondary text-xs font-semibold uppercase tracking-wider">&larr; Previous</span>
      <span class="text-theme-primary mt-1 block font-display text-base">
        Ch. {prev.chapterNumber}: {prev.title.replace(/^\d+\.\s*/, "")}
      </span>
    </a>
  ) : <div />}
  {next ? (
    <a href={base(`/chapters/${next.slug}`)} class="prev-next-link glass-card rounded-2xl p-4 no-underline text-right">
      <span class="text-theme-secondary text-xs font-semibold uppercase tracking-wider">Next &rarr;</span>
      <span class="text-theme-primary mt-1 block font-display text-base">
        Ch. {next.chapterNumber}: {next.title.replace(/^\d+\.\s*/, "")}
      </span>
    </a>
  ) : <div />}
</nav>

<style>
  .prev-next-link {
    display: block;
    transition: transform 200ms ease, box-shadow 200ms ease, background 300ms ease, border-color 300ms ease;
  }

  .prev-next-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgb(0 0 0 / 10%);
  }
</style>
