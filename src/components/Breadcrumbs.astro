---
export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs mb-4 text-sm" aria-label="Breadcrumb">
  <ol class="text-theme-secondary m-0 flex list-none flex-wrap gap-1 p-0">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span aria-hidden="true">/</span>}
        {item.href ? (
          <a href={item.href} class="text-theme-link no-underline">{item.label}</a>
        ) : (
          <span class="text-theme-primary">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
