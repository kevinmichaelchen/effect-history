---
export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs mb-4 text-sm" aria-label="Breadcrumb">
  <ol class="text-theme-secondary m-0 flex list-none flex-wrap gap-1 p-0">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span class="breadcrumb-sep" aria-hidden="true">/</span>}
        {item.href ? (
          <a href={item.href} class="breadcrumb-link">{item.label}</a>
        ) : (
          <span class="text-theme-primary font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumb-sep {
    opacity: 0.4;
    margin: 0 0.1rem;
  }

  .breadcrumb-link {
    color: var(--text-link);
    text-decoration: none;
    padding: 0.1rem 0.35rem;
    border-radius: 0.3rem;
    transition: background 160ms ease, color 160ms ease;
  }

  .breadcrumb-link:hover {
    background: color-mix(in srgb, var(--text-link) 8%, transparent);
  }
</style>
