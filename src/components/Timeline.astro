---
import { eras, timelineEvents } from "../data/chapters";
import EraLegend from "./EraLegend.astro";
import { base } from "../lib/base";

export interface Props {
  /** If true, timeline nodes link to chapter pages instead of anchors */
  linkToPages?: boolean;
  chapterSlugs?: Record<string, string>;
}

const { linkToPages = false, chapterSlugs = {} } = Astro.props;
---

<section class="glass-card mt-2 rounded-2xl p-4" aria-labelledby="timeline-heading">
  <div class="mb-2 flex items-center justify-between">
    <h2 id="timeline-heading" class="font-display text-xl" style="color: var(--text-primary);">Timeline</h2>
    <EraLegend compact />
  </div>
  <div class="timeline-rail" role="list">
    <div
      class="timeline-line"
      style={`background: linear-gradient(90deg, ${eras.map((e, i) => `${e.color} ${(i / eras.length) * 100}%`).join(", ")});`}
      data-timeline-gradient
    ></div>
    {timelineEvents.map((event) => {
      const era = eras[event.eraIndex];
      const chapterSlug = chapterSlugs[event.chapter];
      const href = linkToPages && chapterSlug ? base(`/chapters/${chapterSlug}`) : (event.link || undefined);
      const Tag = href ? "a" : "span";
      return (
        <Tag
          class="timeline-node"
          role="listitem"
          style={`min-width: ${Math.max(48, 60 - timelineEvents.length)}px;`}
          {...(href ? { href } : {})}
        >
          <span class="timeline-node-label">{event.label}</span>
          <span class="timeline-node-dot" style={`background: ${era.color};`} data-era-element data-light-color={era.color} data-dark-color={era.darkColor}></span>
          <span class="timeline-node-year">{event.year}</span>
        </Tag>
      );
    })}
  </div>
</section>

<style>
  .timeline-rail {
    position: relative;
    display: flex;
    align-items: flex-end;
    gap: 0;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 2rem 1rem 1rem;
    scrollbar-width: thin;
    scrollbar-color: var(--text-link) transparent;
  }

  .timeline-rail::-webkit-scrollbar {
    height: 4px;
  }

  .timeline-rail::-webkit-scrollbar-thumb {
    background: var(--text-link);
    border-radius: 2px;
  }

  .timeline-node {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    cursor: pointer;
    text-decoration: none;
    transition: transform 200ms ease;
  }

  .timeline-node:hover {
    transform: translateY(-3px);
  }

  .timeline-node-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--bg-page);
    transition: transform 200ms ease, box-shadow 200ms ease;
    position: relative;
    z-index: 2;
  }

  .timeline-node:hover .timeline-node-dot {
    transform: scale(1.4);
    box-shadow: 0 0 0 4px rgb(38 106 103 / 20%);
  }

  .timeline-node-year {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-top: 0.35rem;
    white-space: nowrap;
  }

  .timeline-node-label {
    font-size: 0.65rem;
    color: var(--text-secondary);
    margin-bottom: 0.4rem;
    white-space: nowrap;
    max-width: 80px;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: center;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 200ms ease, transform 200ms ease;
  }

  .timeline-node:hover .timeline-node-label {
    opacity: 1;
    transform: translateY(0);
  }

  .timeline-line {
    position: absolute;
    bottom: 5px;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 1;
  }
</style>
