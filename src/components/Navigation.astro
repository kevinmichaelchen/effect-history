---
import DarkModeToggle from "./DarkModeToggle.astro";

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/chapters/1-the-lambda-calculus-computation-as-function-19321936", label: "Chapters" },
  { href: "/figures", label: "Figures" },
  { href: "/glossary", label: "Glossary" },
  { href: "/papers", label: "Papers" },
  { href: "/blog", label: "Blog" },
];
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3 md:px-8">
    <a href="/" class="text-theme-primary font-display text-lg font-semibold no-underline">
      Effect Lineage
    </a>
    <div class="flex items-center gap-1">
      <ul class="m-0 flex list-none gap-1 p-0">
        {navLinks.map((link) => {
          const active = link.href === "/" ? currentPath === "/" : currentPath.startsWith(link.href === "/chapters/1-the-lambda-calculus-computation-as-function-19321936" ? "/chapters" : link.href);
          return (
            <li>
              <a
                href={link.href}
                class:list={["nav-link", { "nav-link-active": active }]}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
      <DarkModeToggle />
    </div>
  </div>
</nav>
