---
import BaseLayout from "./BaseLayout.astro";
import ChapterNav from "../components/ChapterNav.astro";
import PrevNextNav from "../components/PrevNextNav.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { plainLanguageGlossary } from "../data/chapters";

export interface ChapterItem {
  chapterNumber: string;
  title: string;
  slug: string;
  readingTime?: number;
}

export interface Props {
  title: string;
  chapterNumber: string;
  chapters: ChapterItem[];
  activeSlug: string;
  prev?: { slug: string; title: string; chapterNumber: string };
  next?: { slug: string; title: string; chapterNumber: string };
}

const { title, chapterNumber, chapters, activeSlug, prev, next } = Astro.props;
const pageTitle = `Ch. ${chapterNumber}: ${title} — Effect Lineage`;
---

<BaseLayout title={pageTitle}>
  <main id="main-content" class="mx-auto max-w-6xl px-6 pb-16 pt-6 md:px-8">
    <Breadcrumbs items={[
      { label: "Home", href: "/" },
      { label: "Chapters", href: `/chapters/${chapters[0].slug}` },
      { label: `${chapterNumber}. ${title}` },
    ]} />

    <section class="grid gap-8 lg:grid-cols-[260px_1fr]" aria-label="Chapter content">
      <ChapterNav chapters={chapters} activeSlug={activeSlug} />

      <div>
        <article id="chapter-content" class="prose prose-lineage dark:prose-invert max-w-none">
          <slot />
        </article>

        <PrevNextNav prev={prev} next={next} />
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ glossaryData: plainLanguageGlossary.map(g => ({ term: g.term, definition: g.definition, link: g.link })) }}>
    // ===== GLOSSARY TOOLTIPS =====
    const article = document.getElementById("chapter-content");
    if (article) {
      const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT, null);
      const textNodes = [];
      let node;
      while ((node = walker.nextNode())) {
        const parent = node.parentElement;
        if (parent && (parent.closest("code") || parent.closest("pre") || parent.closest("a") || parent.closest(".glossary-term") || parent.closest("h2") || parent.closest("h3"))) {
          continue;
        }
        textNodes.push(node);
      }

      const wrappedTerms = new Set();

      // Sort entries by term length descending so multi-word terms match before their sub-parts
      const sortedGlossary = [...glossaryData].sort((a, b) => b.term.length - a.term.length);

      for (const textNode of textNodes) {
        const text = textNode.textContent ?? "";
        for (const entry of sortedGlossary) {
          const escaped = entry.term.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
          // Use word boundaries for single words, lookahead/behind for multi-word terms
          const regex = entry.term.includes(" ") || entry.term.includes("-")
            ? new RegExp(`(?<![\\w-])(${escaped})(?![\\w-])`, "i")
            : new RegExp(`\\b(${escaped})\\b`, "i");
          const match = text.match(regex);
          if (match && !wrappedTerms.has(entry.term.toLowerCase())) {
            const idx = match.index;
            const before = text.slice(0, idx);
            const matched = match[0];
            const after = text.slice(idx + matched.length);

            const beforeNode = document.createTextNode(before);
            const afterNode = document.createTextNode(after);

            const wrapper = document.createElement("span");
            wrapper.className = "glossary-term";
            wrapper.setAttribute("tabindex", "0");
            wrapper.textContent = matched;
            wrapper.dataset.glossaryTerm = entry.term;
            wrapper.dataset.glossaryDef = entry.definition;
            wrapper.dataset.glossaryLink = entry.link || "";

            const parent = textNode.parentNode;
            if (parent) {
              parent.insertBefore(beforeNode, textNode);
              parent.insertBefore(wrapper, textNode);
              parent.insertBefore(afterNode, textNode);
              parent.removeChild(textNode);
            }

            wrappedTerms.add(entry.term.toLowerCase());
            break;
          }
        }
      }
    }

    // ===== REVEAL ANIMATION =====
    const revealTargets = article?.querySelectorAll("h2, h3, p, ul, ol, table, blockquote, pre, hr");
    revealTargets?.forEach((element, index) => {
      element.classList.add("reveal-item");
      element.style.transitionDelay = `${Math.min(index * 14, 210)}ms`;
    });

    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
    );

    revealTargets?.forEach((element) => revealObserver.observe(element));
  </script>

  <script>
    import tippy from "tippy.js";
    import "tippy.js/dist/tippy.css";

    document.querySelectorAll(".glossary-term").forEach((el) => {
      const term = el.getAttribute("data-glossary-term") ?? "";
      const definition = el.getAttribute("data-glossary-def") ?? "";
      const link = el.getAttribute("data-glossary-link");

      const content =
        `<span class="tooltip-term">${term}</span>` +
        `<span class="tooltip-sep"> — </span>` +
        definition +
        (link ? `<div class="tooltip-links"><a href="${link}" target="_blank" rel="noreferrer">Learn more ↗</a></div>` : "");

      tippy(el, {
        content,
        allowHTML: true,
        theme: "glossary",
        placement: "top",
        interactive: true,
        appendTo: document.body,
        maxWidth: 340,
        delay: [100, 0],
        trigger: "mouseenter focus",
      });
    });
  </script>
</BaseLayout>
