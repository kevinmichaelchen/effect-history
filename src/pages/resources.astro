---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { resources, resourceCategories } from "../data/resources";
import type { ResourceCategory } from "../data/resources";
import { base } from "../lib/base";

// Category color map
const categoryColors: Record<ResourceCategory, { bg: string; darkBg: string; text: string; darkText: string; border: string; darkBorder: string }> = {
  "Blog Post":   { bg: "rgb(38 106 103 / 10%)",  darkBg: "rgb(146 210 206 / 10%)", text: "#266a67", darkText: "#92d2ce", border: "rgb(38 106 103 / 22%)",  darkBorder: "rgb(146 210 206 / 20%)" },
  "Video":       { bg: "rgb(180 60 90 / 10%)",    darkBg: "rgb(230 130 150 / 10%)", text: "#a03050", darkText: "#e89aaa", border: "rgb(180 60 90 / 22%)",    darkBorder: "rgb(230 130 150 / 20%)" },
  "Interactive": { bg: "rgb(120 80 180 / 10%)",   darkBg: "rgb(180 150 230 / 10%)", text: "#6b40b0", darkText: "#c4a8e8", border: "rgb(120 80 180 / 22%)",   darkBorder: "rgb(180 150 230 / 20%)" },
  "Website":     { bg: "rgb(219 164 80 / 12%)",   darkBg: "rgb(242 208 157 / 10%)", text: "#8f5c17", darkText: "#f2d09d", border: "rgb(219 164 80 / 25%)",   darkBorder: "rgb(242 208 157 / 20%)" },
};

// Category icons (SVG path data)
const categoryIcons: Record<ResourceCategory, string> = {
  "Blog Post": "article",
  "Video": "video",
  "Interactive": "interactive",
  "Website": "website",
};

// Sort: most recent first (items with dates before undated items)
const sortedResources = [...resources].sort((a, b) => {
  if (!a.date && !b.date) return 0;
  if (!a.date) return 1;
  if (!b.date) return -1;
  return b.date.localeCompare(a.date);
});

// Categories that actually have resources
const activeCategories = resourceCategories.filter((cat) =>
  resources.some((r) => r.category === cat)
);

function formatDate(dateStr?: string): string {
  if (!dateStr) return "";
  // Handle year-only dates
  if (/^\d{4}$/.test(dateStr)) return dateStr;
  const d = new Date(dateStr + "T00:00:00");
  return d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}

function getDomain(url: string): string {
  try {
    const u = new URL(url);
    return u.hostname.replace(/^www\./, "");
  } catch {
    return url;
  }
}
---

<BaseLayout title="Resources — Effect Lineage">
  <main id="main-content" class="mx-auto max-w-6xl px-6 pb-16 pt-6 md:px-8">
    <Breadcrumbs items={[
      { label: "Home", href: base("/") },
      { label: "Resources" },
    ]} />

    <h1 class="text-theme-primary font-display text-4xl">Resources</h1>
    <p class="text-theme-secondary mt-3 max-w-3xl text-lg">
      Blog posts, videos, interactive tools, and other resources for learning about <a href="https://effect.website" target="_blank" rel="noreferrer">Effect</a>.
    </p>

    <!-- Category filter bar -->
    <div class="filter-strip-wrapper">
      <nav class="filter-strip" aria-label="Filter by category">
        <button class="filter-tab is-active" data-category="all">
          <span class="filter-dot" style="--dot-color: var(--text-link);" aria-hidden="true"></span>
          <span class="filter-label">All</span>
          <sup class="filter-sup">{sortedResources.length}</sup>
        </button>
        {activeCategories.map((cat) => {
          const count = resources.filter((r) => r.category === cat).length;
          const colors = categoryColors[cat];
          return (
            <button
              class="filter-tab"
              data-category={cat}
              style={`--dot-color: ${colors.text}; --dot-dark-color: ${colors.darkText}; --pill-bg: ${colors.bg}; --pill-dark-bg: ${colors.darkBg}; --pill-text: ${colors.text}; --pill-dark-text: ${colors.darkText}; --pill-border: ${colors.border}; --pill-dark-border: ${colors.darkBorder};`}
            >
              <span class="filter-dot" aria-hidden="true"></span>
              <span class="filter-label">{cat}</span>
              <sup class="filter-sup">{count}</sup>
            </button>
          );
        })}
      </nav>
      <div class="filter-fade-l" aria-hidden="true"></div>
      <div class="filter-fade-r" aria-hidden="true"></div>
    </div>

    <div id="resources-grid" class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {sortedResources.map((resource, i) => {
        const colors = categoryColors[resource.category];
        return (
          <div class="card-reveal" style={`transition-delay: ${Math.min(i * 40, 600)}ms;`}>
          <a
            href={resource.url}
            target="_blank"
            rel="noreferrer"
            class="resource-card glass-card flex flex-col rounded-2xl p-5 no-underline"
            data-resource-category={resource.category}
            style={`--cat-bg: ${colors.bg}; --cat-dark-bg: ${colors.darkBg}; --cat-text: ${colors.text}; --cat-dark-text: ${colors.darkText}; --cat-border: ${colors.border}; --cat-dark-border: ${colors.darkBorder};`}
          >
            <div class="flex items-start justify-between gap-2">
              <h3 class="text-theme-primary font-display text-base leading-snug">
                {resource.title}
              </h3>
              <span class="resource-type-icon flex-shrink-0 mt-0.5" aria-hidden="true">
                {/* Lucide: book-text */}
                {resource.category === "Blog Post" && (
                  <svg class="icon-book" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path class="book-cover" d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/><path class="book-line-1" d="M8 11h8"/><path class="book-line-2" d="M8 7h6"/></svg>
                )}
                {/* Lucide: clap */}
                {resource.category === "Video" && (
                  <svg class="icon-clap" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.2 6 3 11l-.9-2.4c-.3-1.1.3-2.2 1.3-2.5l13.5-4c1.1-.3 2.2.3 2.5 1.3Z"/><path d="m6.2 5.3 3.1 3.9"/><path d="m12.4 3.4 3.1 4"/><path class="clap-top" d="M3 11h18v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/></svg>
                )}
                {/* Lucide: terminal */}
                {resource.category === "Interactive" && (
                  <svg class="icon-terminal" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline class="terminal-chevron" points="4 17 10 11 4 5"/><line class="terminal-cursor" x1="12" y1="19" x2="20" y2="19"/></svg>
                )}
                {/* Lucide: earth */}
                {resource.category === "Website" && (
                  <svg class="icon-earth" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path class="earth-land" d="M21.54 15H17a2 2 0 0 0-2 2v4.54"/><path class="earth-land" d="M7 3.34V5a3 3 0 0 0 3 3a2 2 0 0 1 2 2c0 1.1.9 2 2 2a2 2 0 0 0 2-2c0-1.1.9-2 2-2h3.17"/><path class="earth-land" d="M11 21.95V18a2 2 0 0 0-2-2a2 2 0 0 1-2-2v-1a2 2 0 0 0-2-2H2.05"/><circle cx="12" cy="12" r="10"/></svg>
                )}
              </span>
            </div>
            <p class="text-theme-secondary mt-1 text-sm">
              {resource.author}{resource.date ? ` \u00b7 ${formatDate(resource.date)}` : ""}
            </p>
            <p class="text-theme-secondary mt-2 flex-1 text-sm">{resource.summary}</p>
            <div class="mt-3 flex flex-wrap items-center gap-1.5">
              <span class="category-badge">{resource.category}</span>
              <span class="resource-domain">
                {getDomain(resource.url)} &nearr;
              </span>
            </div>
          </a>
          </div>
        );
      })}
    </div>
  </main>

  <script is:inline>
    // ===== FILTER INTERACTION =====
    const tabs = document.querySelectorAll(".filter-tab");
    const cards = document.querySelectorAll(".resource-card");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        tabs.forEach((t) => t.classList.remove("is-active"));
        tab.classList.add("is-active");

        const category = tab.getAttribute("data-category");
        let delay = 0;
        cards.forEach((card) => {
          const wrapper = card.closest(".card-reveal") || card;
          const match = category === "all" || card.getAttribute("data-resource-category") === category;
          if (match) {
            wrapper.style.display = "";
            card.style.animation = "none";
            card.offsetHeight; // reflow
            card.style.animation = `resource-filter-in 320ms ease ${delay}ms both`;
            delay += 30;
          } else {
            wrapper.style.display = "none";
          }
        });
      });
    });

    // ===== HORIZONTAL SCROLL FADE =====
    const strip = document.querySelector(".filter-strip");
    const fadeL = document.querySelector(".filter-fade-l");
    const fadeR = document.querySelector(".filter-fade-r");

    function updateFades() {
      if (!strip || !fadeL || !fadeR) return;
      const { scrollLeft, scrollWidth, clientWidth } = strip;
      fadeL.style.opacity = scrollLeft > 4 ? "1" : "0";
      fadeR.style.opacity = scrollLeft + clientWidth < scrollWidth - 4 ? "1" : "0";
    }

    strip?.addEventListener("scroll", updateFades, { passive: true });
    window.addEventListener("resize", updateFades);
    updateFades();

    // ===== STAGGERED CARD REVEAL =====
    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll(".card-reveal").forEach((el) => {
        revealObserver.observe(el);
      });
    }
  </script>

  <style>
    /* ===== FILTER STRIP (horizontally scrollable on mobile) ===== */
    .filter-strip-wrapper {
      position: relative;
      margin-top: 1.75rem;
    }

    .filter-strip {
      display: flex;
      gap: 0.25rem;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding: 0.25rem 0 0.5rem;
      scroll-snap-type: x proximity;
    }

    .filter-strip::-webkit-scrollbar {
      display: none;
    }

    .filter-fade-l,
    .filter-fade-r {
      position: absolute;
      top: 0;
      bottom: 0;
      width: 2.5rem;
      pointer-events: none;
      z-index: 2;
      opacity: 0;
      transition: opacity 200ms ease;
    }

    .filter-fade-l {
      left: 0;
      background: linear-gradient(90deg, var(--bg-page), transparent);
    }

    .filter-fade-r {
      right: 0;
      background: linear-gradient(270deg, var(--bg-page), transparent);
    }

    /* ===== FILTER TAB ===== */
    .filter-tab {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.45rem 0.75rem;
      border: none;
      border-radius: 0.5rem;
      background: transparent;
      font-family: var(--font-body);
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--text-secondary);
      cursor: pointer;
      white-space: nowrap;
      scroll-snap-align: start;
      transition: color 200ms ease, background 200ms ease;
    }

    .filter-tab::after {
      content: "";
      position: absolute;
      bottom: 0;
      left: 50%;
      width: 0;
      height: 2px;
      border-radius: 1px;
      background: var(--dot-color, var(--text-link));
      transform: translateX(-50%);
      transition: width 280ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    :global([data-theme="dark"]) .filter-tab::after {
      background: var(--dot-dark-color, var(--text-link));
    }

    .filter-tab:hover {
      color: var(--text-primary);
      background: var(--border-subtle);
    }

    .filter-tab.is-active {
      color: var(--pill-text, var(--text-link));
      font-weight: 600;
    }

    :global([data-theme="dark"]) .filter-tab.is-active {
      color: var(--pill-dark-text, var(--text-link));
    }

    .filter-tab.is-active::after {
      width: calc(100% - 1rem);
    }

    .filter-tab.is-active .filter-dot {
      transform: scale(1.35);
      box-shadow: 0 0 6px var(--dot-color, var(--text-link));
    }

    :global([data-theme="dark"]) .filter-tab.is-active .filter-dot {
      box-shadow: 0 0 6px var(--dot-dark-color, var(--text-link));
    }

    .filter-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--dot-color, var(--text-link));
      flex-shrink: 0;
      transition: transform 250ms ease, box-shadow 250ms ease;
    }

    :global([data-theme="dark"]) .filter-dot {
      background: var(--dot-dark-color, var(--text-link));
    }

    .filter-label {
      letter-spacing: 0.01em;
    }

    .filter-sup {
      font-size: 0.58rem;
      font-weight: 600;
      opacity: 0.5;
      margin-left: -0.15rem;
      font-variant-numeric: tabular-nums;
    }

    .filter-tab.is-active .filter-sup {
      opacity: 0.8;
    }

    /* ===== RESOURCE CARDS ===== */
    .resource-card {
      border-color: var(--cat-border);
      background: var(--cat-bg);
      cursor: pointer;
      color: inherit;
      transition: transform 200ms ease, box-shadow 200ms ease;
    }

    :global([data-theme="dark"]) .resource-card {
      border-color: var(--cat-dark-border);
      background: var(--cat-dark-bg);
    }

    .resource-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgb(0 0 0 / 8%);
    }

    :global([data-theme="dark"]) .resource-card:hover {
      box-shadow: 0 8px 24px rgb(0 0 0 / 20%);
    }

    .resource-card::before {
      background: radial-gradient(
        circle at 50% 0%,
        color-mix(in srgb, var(--cat-text) 8%, transparent),
        transparent 60%
      );
    }

    :global([data-theme="dark"]) .resource-card::before {
      background: radial-gradient(
        circle at 50% 0%,
        color-mix(in srgb, var(--cat-dark-text) 8%, transparent),
        transparent 60%
      );
    }

    .resource-type-icon {
      color: var(--cat-text);
      opacity: 0.6;
      transition: opacity 200ms ease;
    }

    :global([data-theme="dark"]) .resource-type-icon {
      color: var(--cat-dark-text);
    }

    .resource-card:hover .resource-type-icon {
      opacity: 1;
    }

    /* ===== ICON ANIMATIONS (on card hover) ===== */

    /* Book: text lines draw in */
    .icon-book .book-line-1,
    .icon-book .book-line-2 {
      stroke-dasharray: 10;
      stroke-dashoffset: 10;
      transition: stroke-dashoffset 400ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .icon-book .book-line-2 {
      transition-delay: 100ms;
    }

    .resource-card:hover .icon-book .book-line-1,
    .resource-card:hover .icon-book .book-line-2 {
      stroke-dashoffset: 0;
    }

    /* Clap: top board snaps down */
    .icon-clap .clap-top {
      transform-origin: 3px 11px;
      transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .resource-card:hover .icon-clap .clap-top {
      animation: clap-snap 500ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    @keyframes clap-snap {
      0% { transform: rotate(0deg); }
      30% { transform: rotate(-14deg); }
      60% { transform: rotate(2deg); }
      100% { transform: rotate(0deg); }
    }

    /* Terminal: chevron nudges right, cursor blinks */
    .icon-terminal .terminal-chevron {
      transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .resource-card:hover .icon-terminal .terminal-chevron {
      transform: translateX(1.5px);
    }

    .resource-card:hover .icon-terminal .terminal-cursor {
      animation: cursor-blink 800ms step-end 2;
    }

    @keyframes cursor-blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    /* Earth: gentle spin */
    .icon-earth .earth-land {
      transition: transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
      transform-origin: center;
    }

    .resource-card:hover .icon-earth {
      animation: earth-spin 800ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    @keyframes earth-spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    /* Respect reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .icon-book .book-line-1,
      .icon-book .book-line-2,
      .icon-clap .clap-top,
      .icon-terminal .terminal-chevron,
      .icon-terminal .terminal-cursor,
      .icon-earth,
      .icon-earth .earth-land {
        animation: none !important;
        transition: none !important;
      }
    }

    @keyframes resource-filter-in {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ===== CARD PILLS ===== */
    .category-badge,
    .resource-domain {
      display: inline-flex;
      align-items: center;
      padding: 0.15rem 0.5rem;
      border-radius: 9999px;
      border: 1px solid var(--border-subtle);
      font-size: 0.7rem;
      font-weight: 500;
      white-space: nowrap;
      text-decoration: none;
      transition: background 160ms ease, color 160ms ease, border-color 160ms ease;
    }

    .category-badge {
      color: var(--cat-text);
    }

    :global([data-theme="dark"]) .category-badge {
      color: var(--cat-dark-text);
    }

    .resource-domain {
      color: var(--text-link);
    }
  </style>
</BaseLayout>
