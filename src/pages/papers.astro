    }

    .paper-card:hover .icon-sparkles .spark-2,
    .paper-card:hover .icon-sparkles .spark-3 {
      stroke-dashoffset: 0;
    }

    /* Type-Driven: checkmark draws in */
    .icon-shield .shield-check {
      stroke-dasharray: 10;
      stroke-dashoffset: 10;
      transition: stroke-dashoffset 400ms cubic-bezier(0.22, 1, 0.36, 1) 100ms;
