      stroke-dashoffset: 40;
      transition: stroke-dashoffset 600ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .paper-card:hover .icon-fibers .fiber-2 {
      stroke-dashoffset: 0;
    }

    /* Scala & ZIO: flame flickers */
