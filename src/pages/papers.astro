      25% { transform: scaleY(1.1) scaleX(0.95); }
      50% { transform: scaleY(0.95) scaleX(1.05); }
      75% { transform: scaleY(1.08) scaleX(0.97); }
      100% { transform: scaleY(1) scaleX(1); }
