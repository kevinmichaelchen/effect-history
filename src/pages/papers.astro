---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { papers, paperCategories } from "../data/papers";
import { splitMarkdownByChapter } from "../lib/chapters";

const allChapters = await splitMarkdownByChapter();
const chapterSlugs: Record<string, string> = {};
for (const ch of allChapters) {
  chapterSlugs[ch.chapterNumber] = ch.slug;
}

const papersByCategory = paperCategories.map((category) => ({
  category,
  papers: papers.filter((p) => p.category === category),
})).filter((group) => group.papers.length > 0);
---

<BaseLayout title="Seminal Papers — Effect Lineage">
  <main id="main-content" class="mx-auto max-w-6xl px-6 pb-16 pt-6 md:px-8">
    <Breadcrumbs items={[
      { label: "Home", href: "/" },
      { label: "Seminal Papers" },
    ]} />

    <h1 class="text-theme-primary font-display text-4xl">Seminal Papers</h1>
    <p class="text-theme-secondary mt-3 max-w-3xl text-lg">
      The foundational papers, books, and talks that shaped the ideas behind <a href="https://effect.website" target="_blank" rel="noreferrer">Effect</a>.
      Grouped by topic, spanning from 1934 to the present.
    </p>

    <nav class="mt-6 flex flex-wrap gap-2" aria-label="Jump to category">
      {papersByCategory.map((group) => (
        <a
          href={`#${group.category.toLowerCase().replace(/\s+/g, "-").replace(/&/g, "and")}`}
          class="border-theme-medium text-theme-link bg-theme-card rounded-full border px-3 py-1 text-xs font-semibold no-underline"
        >
          {group.category} ({group.papers.length})
        </a>
      ))}
    </nav>

    {papersByCategory.map((group) => (
      <section class="mt-8" id={group.category.toLowerCase().replace(/\s+/g, "-").replace(/&/g, "and")}>
        <h2 class="text-theme-primary font-display text-2xl">{group.category}</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {group.papers.map((paper) => (
            <div class="glass-card flex flex-col rounded-xl p-5">
              <h3 class="text-theme-primary font-display text-base leading-snug">
                {paper.url ? (
                  <a href={paper.url} target="_blank" rel="noreferrer" class="text-theme-primary no-underline">
                    {paper.title} <span class="text-theme-link text-xs">&nearr;</span>
                  </a>
                ) : paper.title}
              </h3>
              <p class="text-theme-secondary mt-1 text-sm">
                {paper.authors.join(", ")} ({paper.year})
              </p>
              <p class="text-theme-secondary text-xs">{paper.venue}</p>
              <p class="text-theme-secondary mt-2 flex-1 text-sm">{paper.summary}</p>
              <div class="mt-3 flex flex-wrap gap-1">
                {paper.chapters.map((ch) => {
                  const slug = chapterSlugs[ch];
                  return (
                    <a
                      href={slug ? `/chapters/${slug}` : "#"}
                      class="border-theme-subtle text-theme-link rounded-full border px-2 py-0.5 text-xs no-underline"
                    >
                      Ch. {ch}
                    </a>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}
  </main>
</BaseLayout>
