---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { papers, paperCategories } from "../data/papers";
import { splitMarkdownByChapter } from "../lib/chapters";
import { base } from "../lib/base";

const allChapters = await splitMarkdownByChapter();
const chapterSlugs: Record<string, string> = {};
for (const ch of allChapters) {
  chapterSlugs[ch.chapterNumber] = ch.slug;
}

// Category color map — warm/cool tones that work in both light and dark modes
const categoryColors: Record<string, { bg: string; darkBg: string; text: string; darkText: string; border: string; darkBorder: string }> = {
  "Lambda Calculus":                   { bg: "rgb(38 106 103 / 10%)",  darkBg: "rgb(146 210 206 / 10%)", text: "#266a67", darkText: "#92d2ce", border: "rgb(38 106 103 / 22%)",  darkBorder: "rgb(146 210 206 / 20%)" },
  "Curry-Howard Correspondence":       { bg: "rgb(219 164 80 / 12%)",  darkBg: "rgb(242 208 157 / 10%)", text: "#8f5c17", darkText: "#f2d09d", border: "rgb(219 164 80 / 25%)",  darkBorder: "rgb(242 208 157 / 20%)" },
  "Category Theory":                   { bg: "rgb(120 80 180 / 10%)",  darkBg: "rgb(180 150 230 / 10%)", text: "#6b40b0", darkText: "#c4a8e8", border: "rgb(120 80 180 / 22%)",  darkBorder: "rgb(180 150 230 / 20%)" },
  "Monads & Computational Effects":    { bg: "rgb(180 60 90 / 10%)",   darkBg: "rgb(230 130 150 / 10%)", text: "#a03050", darkText: "#e89aaa", border: "rgb(180 60 90 / 22%)",   darkBorder: "rgb(230 130 150 / 20%)" },
  "Functional Programming Languages":  { bg: "rgb(50 130 80 / 10%)",   darkBg: "rgb(120 210 150 / 10%)", text: "#2a7a48", darkText: "#8ed4a4", border: "rgb(50 130 80 / 22%)",   darkBorder: "rgb(120 210 150 / 20%)" },
  "Haskell & Monadic Programming":     { bg: "rgb(90 90 170 / 10%)",   darkBg: "rgb(160 160 230 / 10%)", text: "#4a4aaa", darkText: "#b0b0e6", border: "rgb(90 90 170 / 22%)",   darkBorder: "rgb(160 160 230 / 20%)" },
  "Effect Systems & Algebraic Effects":{ bg: "rgb(200 100 40 / 10%)",  darkBg: "rgb(240 160 100 / 10%)", text: "#b05a1a", darkText: "#f0a868", border: "rgb(200 100 40 / 22%)",  darkBorder: "rgb(240 160 100 / 20%)" },
  "Type-Driven Design":                { bg: "rgb(60 140 160 / 10%)",  darkBg: "rgb(120 200 220 / 10%)", text: "#2a7888", darkText: "#88d0e0", border: "rgb(60 140 160 / 22%)",  darkBorder: "rgb(120 200 220 / 20%)" },
  "Concurrency & Fibers":              { bg: "rgb(160 80 160 / 10%)",  darkBg: "rgb(210 150 210 / 10%)", text: "#904090", darkText: "#d0a0d0", border: "rgb(160 80 160 / 22%)",  darkBorder: "rgb(210 150 210 / 20%)" },
  "Scala & ZIO":                       { bg: "rgb(200 50 50 / 10%)",   darkBg: "rgb(240 120 120 / 10%)", text: "#b03030", darkText: "#e89090", border: "rgb(200 50 50 / 22%)",   darkBorder: "rgb(240 120 120 / 20%)" },
  "Effect":                            { bg: "rgb(38 106 103 / 14%)",  darkBg: "rgb(146 210 206 / 14%)", text: "#266a67", darkText: "#92d2ce", border: "rgb(38 106 103 / 30%)",  darkBorder: "rgb(146 210 206 / 28%)" },
};

// Slugify title for ConnectedPapers URLs
function slugifyTitle(title: string): string {
  return title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
}

// Flatten and sort all papers chronologically (ascending by year)
const sortedPapers = [...papers].sort((a, b) => a.year - b.year);

// Categories that actually have papers (for the filter bar)
const activeCategories = paperCategories.filter((cat) =>
  papers.some((p) => p.category === cat)
);
---

<BaseLayout title="Seminal Papers — Effect Lineage">
  <main id="main-content" class="mx-auto max-w-6xl px-6 pb-16 pt-6 md:px-8">
    <Breadcrumbs items={[
      { label: "Home", href: base("/") },
      { label: "Seminal Papers" },
    ]} />

    <h1 class="text-theme-primary font-display text-4xl">Seminal Papers</h1>
    <p class="text-theme-secondary mt-3 max-w-3xl text-lg">
      The foundational papers, books, and talks that shaped the ideas behind <a href="https://effect.website" target="_blank" rel="noreferrer">Effect</a>.
      Sorted chronologically, spanning from 1934 to the present.
    </p>

    <!-- Category filter bar -->
    <div class="filter-strip-wrapper">
      <nav class="filter-strip" aria-label="Filter by category">
        <button class="filter-tab is-active" data-category="all">
          <span class="filter-dot" style="--dot-color: var(--text-link);" aria-hidden="true"></span>
          <span class="filter-label">All</span>
          <sup class="filter-sup">{sortedPapers.length}</sup>
        </button>
        {activeCategories.map((cat) => {
          const count = papers.filter((p) => p.category === cat).length;
          const colors = categoryColors[cat];
          return (
            <button
              class="filter-tab"
              data-category={cat}
              style={`--dot-color: ${colors?.text}; --dot-dark-color: ${colors?.darkText}; --pill-bg: ${colors?.bg}; --pill-dark-bg: ${colors?.darkBg}; --pill-text: ${colors?.text}; --pill-dark-text: ${colors?.darkText}; --pill-border: ${colors?.border}; --pill-dark-border: ${colors?.darkBorder};`}
            >
              <span class="filter-dot" aria-hidden="true"></span>
              <span class="filter-label">{cat}</span>
              <sup class="filter-sup">{count}</sup>
            </button>
          );
        })}
      </nav>
    </div>

    <div id="papers-grid" class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {sortedPapers.map((paper, i) => {
        const colors = categoryColors[paper.category];
        return (
          <div class="card-reveal" style={`transition-delay: ${Math.min(i * 40, 600)}ms;`}>
          <div
            class="paper-card glass-card flex flex-col rounded-2xl p-5"
            data-paper-category={paper.category}
            style={`--cat-bg: ${colors?.bg}; --cat-dark-bg: ${colors?.darkBg}; --cat-text: ${colors?.text}; --cat-dark-text: ${colors?.darkText}; --cat-border: ${colors?.border}; --cat-dark-border: ${colors?.darkBorder};`}
          >
            <div class="flex items-start justify-between gap-2">
            <h3 class="text-theme-primary font-display text-base leading-snug">
              {paper.title}
            </h3>
            <span class="paper-type-icon flex-shrink-0 mt-0.5" aria-hidden="true">
              {/* Lambda Calculus: Lucide function-square — λ symbol */}
              {paper.category === "Lambda Calculus" && (
                <svg class="icon-lambda" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><path class="lambda-f" d="m9 17 3-8 3 8"/><path class="lambda-f2" d="M9.5 14h5"/></svg>
              )}
              {/* Curry-Howard: Lucide arrow-right-left — correspondence */}
              {paper.category === "Curry-Howard Correspondence" && (
                <svg class="icon-correspond" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path class="arrow-r" d="m16 3 4 4-4 4"/><path class="arrow-r-line" d="M20 7H4"/><path class="arrow-l" d="m8 21-4-4 4-4"/><path class="arrow-l-line" d="M4 17h16"/></svg>
              )}
              {/* Category Theory: Lucide git-merge — morphisms */}
              {paper.category === "Category Theory" && (
                <svg class="icon-morphism" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle class="morph-dot-1" cx="18" cy="18" r="3"/><circle class="morph-dot-2" cx="6" cy="6" r="3"/><path class="morph-path" d="M6 21V9a9 9 0 0 0 9 9"/></svg>
              )}
              {/* Monads: Lucide package — wrapping values */}
              {paper.category === "Monads & Computational Effects" && (
                <svg class="icon-monad" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path class="monad-box" d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path class="monad-inner" d="m3.3 7 8.7 5 8.7-5"/><path class="monad-inner" d="M12 22V12"/></svg>
              )}
              {/* FP Languages: Lucide code — </> */}
              {paper.category === "Functional Programming Languages" && (
                <svg class="icon-code" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline class="code-left" points="16 18 22 12 16 6"/><polyline class="code-right" points="8 6 2 12 8 18"/></svg>
              )}
              {/* Haskell: Lucide layers — monadic layers */}
              {paper.category === "Haskell & Monadic Programming" && (
                <svg class="icon-layers" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path class="layer-1" d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.84Z"/><path class="layer-2" d="m22 12-8.58 4.08a2 2 0 0 1-1.66 0L2 12"/><path class="layer-3" d="m22 17-8.58 4.08a2 2 0 0 1-1.66 0L2 17"/></svg>
              )}
              {/* Effect Systems: Lucide sparkles */}
              {paper.category === "Effect Systems & Algebraic Effects" && (
                <svg class="icon-sparkles" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path class="spark-1" d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path class="spark-2" d="M20 3v4"/><path class="spark-3" d="M22 5h-4"/></svg>
              )}
              {/* Type-Driven: Lucide shield-check */}
              {paper.category === "Type-Driven Design" && (
                <svg class="icon-shield" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path class="shield-check" d="m9 12 2 2 4-4"/></svg>
              )}
              {/* Concurrency: Lucide cable — fibers */}
              {paper.category === "Concurrency & Fibers" && (
                <svg class="icon-fibers" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path class="fiber-1" d="M17 21v-2a1 1 0 0 1-1-1v-1a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v1a1 1 0 0 1-1 1"/><path class="fiber-2" d="M19 15V6.5a1 1 0 0 0-7 0v11a1 1 0 0 1-7 0V9"/><path class="fiber-3" d="M21 21v-2h-4"/><path class="fiber-4" d="M3 5v-2h4"/><path class="fiber-5" d="M7 5a1 1 0 0 1-1 1v1a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V6a1 1 0 0 1 1-1"/></svg>
              )}
              {/* Scala & ZIO: Lucide flame */}
              {paper.category === "Scala & ZIO" && (
                <svg class="icon-flame" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path class="flame-outer" d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
              )}
              {/* Effect: Lucide zap */}
              {paper.category === "Effect" && (
                <svg class="icon-zap" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path class="zap-bolt" d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
              )}
            </span>
            </div>
            <p class="text-theme-secondary mt-1 text-sm">
              {paper.authors.join(", ")} &middot; {paper.year}
            </p>
            <p class="text-theme-secondary text-xs">{paper.venue}</p>
            <p class="text-theme-secondary mt-2 flex-1 text-sm">{paper.summary}</p>
            <div class="mt-3 flex flex-wrap items-center gap-1.5">
              <span class="category-badge">{paper.category}</span>
              {paper.localPdf && (
                <a
                  href={base(paper.localPdf)}
                  target="_blank"
                  rel="noreferrer"
                  class="paper-pdf-link"
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  PDF
                </a>
              )}
              {paper.url && (
                <a
                  href={paper.url}
                  target="_blank"
                  rel="noreferrer"
                  class="paper-pill"
                >
                  Source &nearr;
                </a>
              )}
              {paper.semanticScholarId && (
                <a
                  href={`https://www.connectedpapers.com/main/${paper.semanticScholarId}/${slugifyTitle(paper.title)}/graph`}
                  target="_blank"
                  rel="noreferrer"
                  class="paper-pill"
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><circle cx="5" cy="6" r="1.5"/><circle cx="19" cy="6" r="1.5"/><circle cx="5" cy="18" r="1.5"/><circle cx="19" cy="18" r="1.5"/><line x1="7" y1="7" x2="10" y2="10"/><line x1="14" y1="10" x2="17" y2="7"/><line x1="7" y1="17" x2="10" y2="14"/><line x1="14" y1="14" x2="17" y2="17"/></svg>
                  Connected Papers
                </a>
              )}
              {paper.chapters.map((ch) => {
                const slug = chapterSlugs[ch];
                return (
                  <a
                    href={slug ? base(`/chapters/${slug}`) : "#"}
                    class="paper-pill"
                  >
                    Ch. {ch}
                  </a>
                );
              })}
            </div>
          </div>
          </div>
        );
      })}
    </div>
  </main>

  <script is:inline>
    // ===== FILTER INTERACTION =====
    const tabs = document.querySelectorAll(".filter-tab");
    const cards = document.querySelectorAll(".paper-card");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        tabs.forEach((t) => t.classList.remove("is-active"));
        tab.classList.add("is-active");

        const category = tab.getAttribute("data-category");
        let delay = 0;
        cards.forEach((card) => {
          const wrapper = card.closest(".card-reveal") || card;
          const match = category === "all" || card.getAttribute("data-paper-category") === category;
          if (match) {
            wrapper.style.display = "";
            card.style.animation = "none";
            card.offsetHeight; // reflow
            card.style.animation = `paper-filter-in 320ms ease ${delay}ms both`;
            delay += 30;
          } else {
            wrapper.style.display = "none";
          }
        });
      });
    });

    // ===== STAGGERED CARD REVEAL =====
    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll(".card-reveal").forEach((el) => {
        revealObserver.observe(el);
      });
    }
  </script>

  <style>
    /* ===== FILTER STRIP (horizontally scrollable on mobile) ===== */
    .filter-strip-wrapper {
      position: relative;
      margin-top: 1.75rem;
    }

    .filter-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem;
      padding: 0.25rem 0 0.5rem;
    }

    /* ===== FILTER TAB ===== */
    .filter-tab {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.45rem 0.75rem;
      border: none;
      border-radius: 0.5rem;
      background: transparent;
      font-family: var(--font-body);
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--text-secondary);
      cursor: pointer;
      white-space: nowrap;
      transition: color 200ms ease, background 200ms ease;
    }

    .filter-tab::after {
      content: "";
      position: absolute;
      bottom: 0;
      left: 50%;
      width: 0;
      height: 2px;
      border-radius: 1px;
      background: var(--dot-color, var(--text-link));
      transform: translateX(-50%);
      transition: width 280ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    :global([data-theme="dark"]) .filter-tab::after {
      background: var(--dot-dark-color, var(--text-link));
    }

    .filter-tab:hover {
      color: var(--text-primary);
      background: var(--border-subtle);
    }

    .filter-tab.is-active {
      color: var(--pill-text, var(--text-link));
      font-weight: 600;
    }

    :global([data-theme="dark"]) .filter-tab.is-active {
      color: var(--pill-dark-text, var(--text-link));
    }

    .filter-tab.is-active::after {
      width: calc(100% - 1rem);
    }

    .filter-tab.is-active .filter-dot {
      transform: scale(1.35);
      box-shadow: 0 0 6px var(--dot-color, var(--text-link));
    }

    :global([data-theme="dark"]) .filter-tab.is-active .filter-dot {
      box-shadow: 0 0 6px var(--dot-dark-color, var(--text-link));
    }

    /* Colored dot — like a library spine label */
    .filter-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--dot-color, var(--text-link));
      flex-shrink: 0;
      transition: transform 250ms ease, box-shadow 250ms ease;
    }

    :global([data-theme="dark"]) .filter-dot {
      background: var(--dot-dark-color, var(--text-link));
    }

    .filter-label {
      letter-spacing: 0.01em;
    }

    /* Superscript count — citation-journal style */
    .filter-sup {
      font-size: 0.58rem;
      font-weight: 600;
      opacity: 0.5;
      margin-left: -0.15rem;
      font-variant-numeric: tabular-nums;
    }

    .filter-tab.is-active .filter-sup {
      opacity: 0.8;
    }

    /* ===== PAPER CARDS ===== */
    .paper-card {
      border-color: var(--cat-border);
      background: var(--cat-bg);
    }

    :global([data-theme="dark"]) .paper-card {
      border-color: var(--cat-dark-border);
      background: var(--cat-dark-bg);
    }

    /* Category-colored hover glow (overrides glass-card default) */
    .paper-card::before {
      background: radial-gradient(
        circle at 50% 0%,
        color-mix(in srgb, var(--cat-text) 8%, transparent),
        transparent 60%
      );
    }

    :global([data-theme="dark"]) .paper-card::before {
      background: radial-gradient(
        circle at 50% 0%,
        color-mix(in srgb, var(--cat-dark-text) 8%, transparent),
        transparent 60%
      );
    }

    /* ===== PAPER CATEGORY ICONS ===== */
    .paper-type-icon {
      color: var(--cat-text);
      opacity: 0.5;
      transition: opacity 200ms ease;
    }

    :global([data-theme="dark"]) .paper-type-icon {
      color: var(--cat-dark-text);
    }

    .paper-card:hover .paper-type-icon {
      opacity: 1;
    }

    /* Lambda: letter strokes draw in */
    .icon-lambda .lambda-f,
    .icon-lambda .lambda-f2 {
      stroke-dasharray: 12;
      stroke-dashoffset: 12;
      transition: stroke-dashoffset 400ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .icon-lambda .lambda-f2 {
      transition-delay: 120ms;
    }

    .paper-card:hover .icon-lambda .lambda-f,
    .paper-card:hover .icon-lambda .lambda-f2 {
      stroke-dashoffset: 0;
    }

    /* Curry-Howard: arrows slide in from edges */
    .icon-correspond .arrow-r,
    .icon-correspond .arrow-r-line {
      transition: transform 350ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .icon-correspond .arrow-l,
    .icon-correspond .arrow-l-line {
      transition: transform 350ms cubic-bezier(0.22, 1, 0.36, 1) 80ms;
    }

    .paper-card:hover .icon-correspond .arrow-r,
    .paper-card:hover .icon-correspond .arrow-r-line {
      transform: translateX(2px);
    }

    .paper-card:hover .icon-correspond .arrow-l,
    .paper-card:hover .icon-correspond .arrow-l-line {
      transform: translateX(-2px);
    }

    /* Category Theory: path draws in */
    .icon-morphism .morph-path {
      stroke-dasharray: 30;
      stroke-dashoffset: 30;
      transition: stroke-dashoffset 500ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .paper-card:hover .icon-morphism .morph-path {
      stroke-dashoffset: 0;
    }

    /* Monads: inner lines draw in */
    .icon-monad .monad-inner {
      stroke-dasharray: 16;
      stroke-dashoffset: 16;
      transition: stroke-dashoffset 400ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .paper-card:hover .icon-monad .monad-inner {
      stroke-dashoffset: 0;
    }

    /* FP Languages: brackets tilt inward */
    .icon-code .code-left {
      transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1);
      transform-origin: right center;
    }

    .icon-code .code-right {
      transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1);
      transform-origin: left center;
    }

    .paper-card:hover .icon-code .code-left {
      transform: translateX(1.5px);
    }

    .paper-card:hover .icon-code .code-right {
      transform: translateX(-1.5px);
    }

    /* Haskell: layers fan apart */
    .icon-layers .layer-2 {
      transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1);
