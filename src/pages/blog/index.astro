---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { base } from "../../lib/base";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Blog — Effect Lineage">
  <main id="main-content" class="mx-auto max-w-4xl px-6 pb-16 pt-6 md:px-8">
    <Breadcrumbs items={[
      { label: "Home", href: base("/") },
      { label: "Blog" },
    ]} />

    <h1 class="text-theme-primary font-display mb-2 text-3xl md:text-4xl">Blog</h1>
    <p class="text-theme-secondary mb-8 max-w-2xl text-lg">
      Essays on Effect, functional programming, and the ideas behind them.
    </p>

    <div class="space-y-4">
      {posts.map((post) => {
        const formattedDate = post.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        return (
          <a href={base(`/blog/${post.id}`)} class="blog-card glass-card block rounded-2xl p-6 no-underline">
            <h2 class="text-theme-primary font-display text-xl leading-snug">{post.data.title}</h2>
            <p class="text-theme-secondary mt-2 text-sm leading-relaxed">{post.data.description}</p>
            <div class="text-theme-secondary mt-3 flex flex-wrap items-center gap-3 text-xs">
              <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {post.data.tags.map((tag: string) => (
                    <span class="blog-tag rounded-full px-2 py-0.5 font-medium">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </main>

  <style>
    .blog-card {
      transition: transform 200ms ease, box-shadow 200ms ease, background 300ms ease, border-color 300ms ease;
    }

    .blog-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgb(0 0 0 / 10%);
    }

    .blog-tag {
      border: 1px solid var(--border-subtle);
      color: var(--text-link);
      background: transparent;
    }
  </style>
</BaseLayout>
