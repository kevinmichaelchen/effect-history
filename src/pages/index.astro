---
import BaseLayout from "../layouts/BaseLayout.astro";
import Timeline from "../components/Timeline.astro";
import EraLegend from "../components/EraLegend.astro";
import ChapterCard from "../components/ChapterCard.astro";
import FigureCard from "../components/FigureCard.astro";
import GlossaryCard from "../components/GlossaryCard.astro";
import {
  chapterSummaries,
  plainLanguageGlossary,
  chapterMeta,
  eras,
  figureMeta,
} from "../data/chapters";
import { splitMarkdownByChapter } from "../lib/chapters";
import figures from "../data/figures.generated.json";

const allChapters = await splitMarkdownByChapter();

// Build chapter slug lookup
const chapterSlugs: Record<string, string> = {};
for (const ch of allChapters) {
  chapterSlugs[ch.chapterNumber] = ch.slug;
}

const chapterCards = allChapters.map((chapter) => {
  const meta = chapterMeta[chapter.chapterNumber];
  return {
    ...chapter,
    summary: chapterSummaries[chapter.chapterNumber] ?? "A key milestone in Effect's intellectual history.",
    meta,
  };
});

const figuresWithImages = (
  figures as Array<{
    name: string;
    image: string;
    sourceDomain?: string;
    sourcePage?: string;
  }>
).filter((figure) => figure.image);

const enrichedFigures = figuresWithImages.map((figure) => {
  const meta = figureMeta[figure.name];
  return {
    ...figure,
    meta,
    era: meta ? eras[meta.eraIndex] : undefined,
  };
});

const sortedFigures = enrichedFigures.sort((a, b) => {
  const aIdx = a.meta?.eraIndex ?? 99;
  const bIdx = b.meta?.eraIndex ?? 99;
  return aIdx - bIdx;
});

const now = new Date();
const updatedDate = now.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const readingTimes: Record<string, number> = {
  "1": 3, "2": 5, "3": 6, "4": 4, "5": 4, "6": 5,
  "7": 4, "8": 3, "9": 4, "10": 5, "11": 2, "12": 2,
};

const heroYears = [
  { year: "1932", color: eras[0].color, darkColor: eras[0].darkColor },
  { year: "1945", color: eras[0].color, darkColor: eras[0].darkColor },
  { year: "1958", color: eras[1].color, darkColor: eras[1].darkColor },
  { year: "1973", color: eras[1].color, darkColor: eras[1].darkColor },
  { year: "1989", color: eras[2].color, darkColor: eras[2].darkColor },
  { year: "2009", color: eras[3].color, darkColor: eras[3].darkColor },
  { year: "2020", color: eras[4].color, darkColor: eras[4].darkColor },
];
---

<BaseLayout title="The Intellectual Lineage of Effect">
  <header class="border-theme-subtle relative overflow-hidden border-b">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="orb absolute -left-12 top-20 h-40 w-40 rounded-full bg-teal-200/55 blur-2xl"></div>
      <div class="orb absolute right-6 top-8 h-44 w-44 rounded-full bg-amber-200/65 blur-2xl [animation-delay:1.8s]"></div>
    </div>

    <div class="mx-auto max-w-6xl px-6 pb-12 pt-16 md:px-8 md:pb-16 md:pt-24">
      <p class="border-theme-medium bg-theme-card text-theme-secondary mb-3 inline-flex rounded-full border px-3 py-1 text-sm font-semibold tracking-wide">
        Interactive Historical Guide
      </p>
      <h1 class="text-theme-primary max-w-4xl font-display text-4xl leading-tight md:text-6xl">
        The Intellectual Lineage of <a href="https://effect.website" class="text-theme-link no-underline">Effect</a>
      </h1>
      <p class="text-theme-secondary mt-5 max-w-3xl text-lg md:text-xl">
        A readable, visual journey from foundational logic to modern <a href="https://www.typescriptlang.org/" target="_blank" rel="noreferrer">TypeScript</a> effects. No formal math background
        needed: this site adds context and plain-language anchors as you explore the original essay.
      </p>

      <!-- Convergence year animation -->
      <div class="hero-years">
        {heroYears.map((item, i) => (
          <span
            class="hero-year"
            style={`animation-delay: ${i * 120}ms; color: ${item.color};`}
            data-dark-color={item.darkColor}
            data-light-color={item.color}
          >
            {item.year}
            <span style={`background: ${item.color};`} class="absolute bottom-[-2px] left-0 h-[2px] w-full origin-left scale-x-0" data-hero-line></span>
          </span>
        ))}
        <span class="hero-converge-arrow" style={`animation-delay: ${heroYears.length * 120 + 200}ms;`}>&rarr;</span>
        <a href="https://effect.website" target="_blank" rel="noreferrer" class="hero-effect-label no-underline" style={`animation-delay: ${heroYears.length * 120 + 400}ms;`}>Effect</a>
      </div>

      <p class="text-theme-secondary mt-6 text-sm">
        Tracing <strong>90+ years</strong> of breakthroughs across
        <a href="https://en.wikipedia.org/wiki/Lambda_calculus" target="_blank" rel="noreferrer">lambda calculus</a>,
        <a href="https://en.wikipedia.org/wiki/Category_theory" target="_blank" rel="noreferrer">category theory</a>,
        <a href="https://en.wikipedia.org/wiki/Type_theory" target="_blank" rel="noreferrer">type theory</a>, and
        <a href="https://en.wikipedia.org/wiki/Functional_programming" target="_blank" rel="noreferrer">functional programming</a>
        into one coherent narrative.
      </p>
    </div>
  </header>

  <main id="main-content" class="mx-auto max-w-6xl px-6 pb-16 pt-8 md:px-8 md:pt-10">

    <!-- Timeline visualization -->
    <Timeline linkToPages chapterSlugs={chapterSlugs} />

    <!-- Glossary -->
    <section class="glass-card mt-6 rounded-2xl p-6" aria-labelledby="start-here">
      <div class="flex items-center justify-between">
        <h2 id="start-here" class="text-theme-primary font-display text-2xl">Start Here (No <abbr title="Computer Science">CS</abbr> Degree Required)</h2>
        <a href="/glossary" class="text-theme-link text-sm font-semibold">View all &rarr;</a>
      </div>
      <p class="text-theme-secondary mt-2 max-w-3xl">
        This topic can look intimidating because of the terminology. Treat each chapter as a story about one big idea,
        not a test. The goal is understanding relationships, not memorizing formal proofs.
      </p>
      <dl class="mt-4 grid gap-3 md:grid-cols-2">
        {plainLanguageGlossary.map((entry) => (
          <GlossaryCard
            term={entry.term}
            definition={entry.definition}
            link={entry.link}
            chapters={entry.chapters}
            chapterSlugs={chapterSlugs}
            linkToChapterPages
          />
        ))}
      </dl>
    </section>

    <!-- Chapter Overview -->
    <section class="mt-8" aria-labelledby="chapter-overview">
      <div class="mb-4 flex items-end justify-between gap-3">
        <h2 id="chapter-overview" class="text-theme-primary font-display text-3xl">Chapter Overview</h2>
        <p class="text-theme-secondary text-sm">Updated {updatedDate}</p>
      </div>
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {chapterCards.map((chapter) => (
          <ChapterCard
            chapterNumber={chapter.chapterNumber}
            title={chapter.title}
            slug={chapter.slug}
            summary={chapter.summary}
            meta={chapter.meta}
            readingTime={readingTimes[chapter.chapterNumber]}
            linkToPage
          />
        ))}
      </div>
    </section>

    <!-- Historical Figures Gallery (preview) -->
    {sortedFigures.length > 0 && (
      <section class="mt-10" aria-labelledby="people-gallery">
        <div class="flex items-center justify-between">
          <h2 id="people-gallery" class="text-theme-primary font-display text-3xl">Historical Figures</h2>
          <a href="/figures" class="text-theme-link text-sm font-semibold">View all &rarr;</a>
        </div>
        <p class="text-theme-secondary mt-2 max-w-3xl">
          The people who shaped the ideas behind <a href="https://effect.website" target="_blank" rel="noreferrer">Effect</a>.
          Hover for contributions and links.
        </p>
        <div class="mt-2">
          <EraLegend />
        </div>
        <ul class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {sortedFigures.slice(0, 6).map((figure) => (
            <FigureCard
              name={figure.name}
              image={figure.image}
              sourcePage={figure.sourcePage}
              meta={figure.meta}
              era={figure.era}
              chapterSlugs={chapterSlugs}
              linkToChapterPages
            />
          ))}
        </ul>
        {sortedFigures.length > 6 && (
          <div class="mt-4 text-center">
            <a href="/figures" class="border-theme-medium text-theme-link bg-theme-card inline-flex items-center gap-1 rounded-full border px-4 py-2 text-sm font-semibold no-underline">
              See all {sortedFigures.length} figures &rarr;
            </a>
          </div>
        )}
      </section>
    )}

    <!-- Papers preview -->
    <section class="mt-10" aria-labelledby="papers-preview">
      <div class="flex items-center justify-between">
        <h2 id="papers-preview" class="text-theme-primary font-display text-3xl">Seminal Papers</h2>
        <a href="/papers" class="text-theme-link text-sm font-semibold">View all &rarr;</a>
      </div>
      <p class="text-theme-secondary mt-2 max-w-3xl">
        The foundational papers and references behind the narrative, spanning 90 years of breakthroughs.
      </p>
      <div class="mt-4 text-center">
        <a href="/papers" class="border-theme-medium text-theme-link bg-theme-card inline-flex items-center gap-1 rounded-full border px-4 py-2 text-sm font-semibold no-underline">
          Browse all papers &rarr;
        </a>
      </div>
    </section>
  </main>

  <script is:inline>
    // ===== ANIMATE HERO LINES =====
    document.querySelectorAll("[data-hero-line]").forEach((line, i) => {
      setTimeout(() => {
        line.style.transition = "transform 400ms ease";
        line.style.transform = "scaleX(1)";
      }, i * 120 + 400);
    });
  </script>

  <style>
    .hero-years {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1.2rem;
      margin-top: 1.5rem;
    }

    .hero-year {
      font-family: var(--font-display);
      font-size: clamp(1.4rem, 3vw, 2.2rem);
      font-weight: 300;
      opacity: 0;
      animation: hero-year-in 600ms ease forwards;
      color: var(--text-secondary);
      position: relative;
    }

    .hero-year::after {
      content: "";
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 100%;
      height: 2px;
      transform: scaleX(0);
      transform-origin: left;
      animation: hero-line-in 400ms ease forwards;
    }

    @keyframes hero-year-in {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes hero-line-in {
      to {
        transform: scaleX(1);
      }
    }

    .hero-converge-arrow {
      font-family: var(--font-display);
      font-size: clamp(1.4rem, 3vw, 2.2rem);
      color: var(--text-link);
      opacity: 0;
      animation: hero-year-in 600ms ease forwards;
    }

    .hero-effect-label {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 3.5vw, 2.6rem);
      font-weight: 600;
      color: var(--text-link);
      opacity: 0;
      animation: hero-year-in 800ms ease forwards;
    }
  </style>
</BaseLayout>
